{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Zircon",
    "scopeName": "source.zircon",
    "patterns": [
        { "include": "#comments" },
        { "include": "#preprocessor" },
        { "include": "#attributes" },
        { "include": "#constants" },
        { "include": "#types" },
        { "include": "#keywords" },
        { "include": "#operators" },
        { "include": "#entities" },
        { "include": "#numbers" },
        { "include": "#strings" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.zircon", "match": "//.*$" },
                { "name": "comment.block.zircon", "begin": "/\\*", "end": "\\*/" }
            ]
        },
        "preprocessor": {
            "patterns": [
                {
                    "name": "meta.preprocessor.zircon",
                    "begin": "#\\[",
                    "end": "\\]",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.preprocessor.begin.zircon" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.preprocessor.end.zircon" }
                    },
                    "patterns": [
                        { "include": "#comments" },
                        { "name": "keyword.control.directive.zircon", "match": "\\b(if|elif|else|endif|include|error|warning)\\b" },
                        { "include": "#constants" },
                        { "include": "#operators" },
                        { "include": "#numbers" },
                        { "include": "#strings" }
                    ]
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.decorator.zircon",
                    "begin": "@",
                    "beginCaptures": {
                        "0": { "name": "support.name.decorator.zircon" }
                    },
                    "end": "(?=\\s|$)",
                    "patterns": [
                        {
                            "name": "support.name.decorator.zircon",
                            "match": "[A-Za-z_][A-Za-z0-9_]*"
                        },
                        {
                            "begin": "\\(",
                            "beginCaptures": {
                                "0": { "name": "punctuation.bracket.round.decorator.zircon" }
                            },
                            "end": "\\)",
                            "endCaptures": {
                                "0": { "name": "punctuation.bracket.round.decorator.zircon" }
                            },
                            "patterns": [
                                { "include": "#comments" },
                                { "include": "#preprocessor" },
                                { "include": "#constants" },
                                { "include": "#operators" },
                                { "include": "#numbers" },
                                { "include": "#strings" }
                            ]
                        }
                    ]
                }
            ]
        },
        "constants": {
            "patterns": [
                { "name": "constant.language.zircon", "match": "\\b(true|false|null)\\b" },
                { "name": "support.constant.zircon", "match": "\\bzero\\b" }
            ]
        },
        "types": {
            "patterns": [
                { "name": "storage.type.zircon", "match": "\\b(void|bool|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64)\\b" }
            ]
        },
        "keywords": {
            "patterns": [
                { "name": "keyword.control.flow.zircon", "match": "\\b(if|else|for|while|loop|match|ret|break|continue)\\b" },
                { "name": "keyword.declaration.zircon", "match": "\\b(let|mut|const|volatile|func|class|type|enum|impl|pub|priv|extern|asm|async|await|static)\\b" },
                { "name": "keyword.operator.word.zircon", "match": "\\b(as|op|new|del|in)\\b" }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.compound.zircon",
                    "match": "(\\+=|-=|\\*=|/=|%=|&=|\\^=|\\|=|<<=|>>=)"
                },
                {
                    "name": "keyword.operator.comparison.zircon",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.zircon",
                    "match": "(=)"
                },
                {
                    "name": "keyword.operator.arithmetic.zircon",
                    "match": "(\\+|-|\\*|/|%|\\+\\+|--)"
                },
                {
                    "name": "keyword.operator.logical.zircon",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.bitwise.zircon",
                    "match": "(&|\\||\\^|~|<<|>>)"
                },
                {
                    "name": "keyword.operator.ternary.zircon",
                    "match": "(\\?|:)"
                }
            ]
        },
        "entities": {
            "patterns": [
                { "name": "entity.name.type.zircon", "match": "(?<=\\b(class|enum)\\s+)[A-Za-z_][A-Za-z0-9_]*" },
                { "name": "entity.name.function.zircon", "match": "[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()" }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.hex.zircon", "match": "\\b0[xX][0-9a-fA-F]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.binary.zircon", "match": "\\b0[bB][01]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.octal.zircon", "match": "\\b0[oO][0-7]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.decimal.zircon", "match": "\\b[0-9]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.float.zircon", "match": "\\b([0-9]+\\.[0-9]*|[0-9]*\\.[0-9]+)([eE][-+]?[0-9]*)?(f32|f64)?\\b" },
                { "name": "constant.numeric.float.exp.zircon", "match": "\\b[0-9]+[eE][-+]?[0-9]*(f32|f64)?\\b" }
            ]
        },
        "strings": {
            "patterns": [
                { "name": "string.quoted.double.zircon", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.zircon", "match": "\\\\." }] },
                { "name": "string.quoted.single.zircon", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.zircon", "match": "\\\\." }] }
            ]
        }
    }
}