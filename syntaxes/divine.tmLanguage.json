{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Divine",
    "scopeName": "source.divine",
    "patterns": [
        { "include": "#comments" },
        { "include": "#preprocessor" },
        { "include": "#constants" },
        { "include": "#types" },
        { "include": "#keywords" },
        { "include": "#operators" },
        { "include": "#entities" },
        { "include": "#numbers" },
        { "include": "#strings" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.divine", "match": "//.*$" },
                { "name": "comment.block.divine", "begin": "/\\*", "end": "\\*/" }
            ]
        },
        "keywords": {
            "patterns": [
                { "name": "keyword.control.flow.divine", "match": "\\b(if|else|for|while|loop|match|ret|break|continue)\\b" },
                { "name": "keyword.declaration.divine", "match": "\\b(let|mut|const|volatile|func|class|type|enum|impl|pub|priv|extern|use|asm|namespace|async|await|static)\\b" },
                { "name": "keyword.operator.word.divine", "match": "\\b(as|op|new|del|in)\\b" },
                { "name": "keyword.import.divine", "match": "\\b(include)\\b" }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.compound.divine",
                    "match": "(\\+=|-=|\\*=|/=|%=|&=|\\^=|\\|=|<<=|>>=)"
                },
                {
                    "name": "keyword.operator.comparison.divine",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.divine",
                    "match": "(=)"
                },
                {
                    "name": "keyword.operator.arithmetic.divine",
                    "match": "(\\+|-|\\*|/|%|\\+\\+|--)"
                },
                {
                    "name": "keyword.operator.logical.divine",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.bitwise.divine",
                    "match": "(&|\\||\\^|~|<<|>>)"
                },
                {
                    "name": "keyword.operator.ternary.divine",
                    "match": "(\\?|:)"
                }
            ]
        },
        "preprocessor": {
            "patterns": [
                {
                    "name": "meta.preprocessor.divine",
                    "begin": "#\\[",
                    "end": "\\]",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.preprocessor.begin.divine" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.preprocessor.end.divine" }
                    },
                    "patterns": [
                        { "name": "keyword.control.directive.divine", "match": "\\b(if|elif|else|endif|error|warning)\\b" }
                    ]
                }
            ]
        },
        "types": {
            "patterns": [
                { "name": "storage.type.divine", "match": "\\b(void|bool|char|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64)\\b" }
            ]
        },
        "constants": {
            "patterns": [
                { "name": "constant.language.divine", "match": "\\b(true|false|null)\\b" }
            ]
        },
        "entities": {
            "patterns": [
                { "name": "entity.name.type.divine", "match": "(?<=\\b(class|enum)\\s+)[A-Za-z_][A-Za-z0-9_]*" },
                { "name": "entity.name.function.divine", "match": "[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()" }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.hex.divine", "match": "\\b0[xX][0-9a-fA-F]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.binary.divine", "match": "\\b0[bB][01]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.octal.divine", "match": "\\b0[oO][0-7]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.decimal.divine", "match": "\\b[0-9]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.float.divine", "match": "\\b([0-9]+\\.[0-9]*|[0-9]*\\.[0-9]+)([eE][-+]?[0-9]*)?(f32|f64)?\\b" },
                { "name": "constant.numeric.float.exp.divine", "match": "\\b[0-9]+[eE][-+]?[0-9]*(f32|f64)?\\b" }
            ]
        },
        "strings": {
            "patterns": [
                { "name": "string.quoted.double.divine", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.divine", "match": "\\\\." }] },
                { "name": "string.quoted.single.divine", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.divine", "match": "\\\\." }] }
            ]
        }
    }
}