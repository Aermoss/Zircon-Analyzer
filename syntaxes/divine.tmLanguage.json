{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Divine",
    "scopeName": "source.divine",
    "patterns": [
        { "include": "#comments" },
        { "include": "#constants" },
        { "include": "#types" },
        { "include": "#keywords" },
        { "include": "#entities" },
        { "include": "#numbers" },
        { "include": "#strings" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.divine", "match": "//.*$" },
                { "name": "comment.block.divine", "begin": "/\\*", "end": "\\*/" }
            ]
        },
        "keywords": {
            "patterns": [
                { "name": "keyword.control.flow.divine", "match": "\\b(if|else|for|while|ret|break|continue)\\b" },
                { "name": "keyword.declaration.divine", "match": "\\b(let|mut|const|func|class|type|enum|impl|mod|pub|priv|extern|use)\\b" },
                { "name": "keyword.operator.divine", "match": "\\b(as|op|new|delete)\\b" },
                { "name": "keyword.import.divine", "match": "\\binclude\\b" }
            ]
        },
        "types": {
            "patterns": [
                { "name": "storage.type.divine", "match": "\\b(void|bool|char|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64)\\b" }
            ]
        },
        "constants": {
            "patterns": [
                { "name": "constant.language.divine", "match": "\\b(true|false|null)\\b" }
            ]
        },
        "entities": {
            "patterns": [
                { "name": "entity.name.type.divine", "match": "(?<=\\b(class|enum)\\s+)[A-Za-z_][A-Za-z0-9_]*" },
                { "name": "entity.name.function.divine", "match": "(?<=\\bfunc\\s+)[A-Za-z_][A-Za-z0-9_]*" },
                { "name": "entity.name.function.divine", "match": "[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()" }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.hex.divine", "match": "\\b0[xX][0-9a-fA-F]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.binary.divine", "match": "\\b0[bB][01]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.octal.divine", "match": "\\b0[oO][0-7]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.decimal.divine", "match": "\\b[0-9]+(i(8|16|32|64|128)|u(8|16|32|64|128))?\\b" },
                { "name": "constant.numeric.float.divine", "match": "\\b([0-9]+\\.[0-9]*|[0-9]*\\.[0-9]+)([eE][-+]?[0-9]*)?(f32|f64)?\\b" },
                { "name": "constant.numeric.float.exp.divine", "match": "\\b[0-9]+[eE][-+]?[0-9]*(f32|f64)?\\b" }
            ]
        },
        "strings": {
            "patterns": [
                { "name": "string.quoted.double.divine", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.divine", "match": "\\\\." }] },
                { "name": "string.quoted.single.divine", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.divine", "match": "\\\\." }] }
            ]
        }
    }
}