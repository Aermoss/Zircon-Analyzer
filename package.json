{
    "name": "zircon-analyzer",
    "displayName": "Zircon Analyzer",
    "description": "Zircon language support for Visual Studio Code.",
    "publisher": "zircon-lang",
    "version": "0.1.5",
    "engines": {
        "vscode": "^1.103.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Aermoss/Zircon-Analyzer"
    },
    "dependencies": {
        "vscode-languageclient": "^8.1.0"
    },
    "contributes": {
        "languages": [
            {
                "id": "zircon",
                "aliases": [
                    "Zircon"
                ],
                "extensions": [
                    ".zir"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "zircon",
                "scopeName": "source.zircon",
                "path": "./syntaxes/zircon.tmLanguage.json"
            }
        ]
    },
    "main": "./extension.js"
}