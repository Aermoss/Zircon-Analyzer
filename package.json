{
    "name": "divine",
    "displayName": "Divine",
    "description": "Language support for Divine.",
    "publisher": "Aermoss",
    "version": "0.0.7",
    "engines": {
        "vscode": "^1.103.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Aermoss/Divine-Extension"
    },
    "dependencies": {
        "vscode-languageclient": "^8.0.0"
    },
    "contributes": {
        "languages": [
            {
                "id": "divine",
                "aliases": ["Divine"],
                "extensions": [".div"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "divine",
                "scopeName": "source.divine",
                "path": "./syntaxes/divine.tmLanguage.json"
            }
        ]
    },
    "main": "./extension.js"
}